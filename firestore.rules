rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════

    // Admin = tài khoản Firebase Auth đã đăng nhập và có custom claim admin.
    // Set claim admin bằng Firebase Admin SDK hoặc Firebase CLI.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ─── Validate config/settings ───────────────────────────
    // Chỉ cho phép đúng các field đang dùng, tất cả phải là string
    function validateConfig() {
      let d = request.resource.data;
      return (!('logo_url'       in d) || d.logo_url       is string)
          && (!('background_url' in d) || d.background_url is string)
          && (!('bank_name'       in d) || d.bank_name      is string)
          && (!('bank_stk'        in d) || d.bank_stk       is string)
          && (!('bank_owner'      in d) || d.bank_owner     is string)
          && (!('bank_bin'        in d) || d.bank_bin       is string)
          && (!('contact_phone'   in d) || d.contact_phone  is string)
          && (!('contact_email'   in d) || d.contact_email  is string)
          && (!('contact_address' in d) || d.contact_address is string)
          && (!('contact_hours'   in d) || d.contact_hours  is string)
          && (!('contact_fb'      in d) || d.contact_fb     is string)
          && (!('contact_zalo'    in d) || d.contact_zalo   is string);
    }

    // ─── Validate admin presence tracking ─────────────────────
    function validateAdminOnline() {
      let d = request.resource.data;
      return d.keys().hasOnly(['online', 'lastSeen'])
          && d.online   is bool
          && d.lastSeen is timestamp;
    }

    function validateReportBackupConfig() {
      let d = request.resource.data;
      let allowed = ['backupCount', 'lastBackupAt', 'lastBackupBy', 'updatedAt', 'restoredFrom', 'restoredAt'];
      return d.keys().hasOnly(allowed)
          && (!('backupCount' in d) || (d.backupCount is number && d.backupCount >= 0))
          && (!('lastBackupAt' in d) || d.lastBackupAt is timestamp)
          && (!('lastBackupBy' in d) || d.lastBackupBy is string)
          && (!('updatedAt' in d) || d.updatedAt is timestamp)
          && (!('restoredFrom' in d) || d.restoredFrom is string)
          && (!('restoredAt' in d) || d.restoredAt is timestamp);
    }

    // ─── Validate products ───────────────────────────────────
    // name: string không rỗng, tối đa 200 ký tự
    // price: số không âm
    // image: string không rỗng
    // category: phải thuộc danh sách cho phép
    function validateProduct() {
      let d = request.resource.data;
      let allowed = ['name', 'price', 'image', 'category', 'description', 'barcode', 'active', 'deletedAt'];
      return d.keys().hasOnly(allowed)
          && d.keys().hasAll(['name', 'price', 'image', 'category', 'barcode'])
          && d.name     is string && d.name.size()     > 0 && d.name.size()  <= 200
          && d.price    is number && d.price            >= 0
          && d.image    is string && d.image.size()    > 0
          && d.category is string
          && d.category in ['yen', 'sam', 'us-japan', 'food-drink']
          && d.barcode  is string && d.barcode.size()   > 0 && d.barcode.size() <= 100
          && (!('description' in d) || (d.description is string && d.description.size() <= 1000))
          && (!('active' in d) || d.active is bool)
          && (!('deletedAt' in d) || d.deletedAt is timestamp);
    }

    function validateRestockRequest() {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'orderId', 'productId', 'productName',
          'orderedQty', 'availableQty', 'shortageQty',
          'customerName', 'customerPhone', 'customerAddress',
          'status', 'createdAt', 'updatedAt'
        ])
        && d.keys().hasAll([
          'orderId', 'productId', 'productName',
          'orderedQty', 'availableQty', 'shortageQty',
          'customerName', 'customerPhone', 'customerAddress',
          'status', 'createdAt'
        ])
        && d.orderId is string && d.orderId.size() > 0
        && d.productId is string && d.productId.size() > 0
        && d.productName is string && d.productName.size() > 0
        && d.orderedQty is number && d.orderedQty >= 0
        && d.availableQty is number && d.availableQty >= 0
        && d.shortageQty is number && d.shortageQty >= 0
        && d.customerName is string && d.customerName.size() > 0 && d.customerName.size() <= 100
        && d.customerPhone is string && d.customerPhone.size() > 0 && d.customerPhone.size() <= 20
        && d.customerAddress is string && d.customerAddress.size() > 0 && d.customerAddress.size() <= 300
        && d.status in ['requested', 'fulfilled']
        && d.createdAt is timestamp
        && (!('updatedAt' in d) || d.updatedAt is timestamp);
    }

    // ─── Validate orders ─────────────────────────────────────
    // Đảm bảo client không thể gửi dữ liệu rác / field lạ lên Firestore
    function validateOrderItems(items) {
      return items is list
          && items.size() > 0 && items.size() <= 50;
    }

    function validateStockShortages(shortages) {
      return shortages is list
          && shortages.size() <= 50;
    }

    function validateOrder() {
      let d = request.resource.data;
      let requiredKeys = [
        'customerName', 'customerPhone', 'customerAddress',
        'paymentMethod', 'items', 'total', 'timestamp',
        'status', 'source', 'createdAt'
      ];
      let optionalKeys = ['loyaltyCustomer', 'loyaltyPhone', 'loyaltyOffer', 'stockReduced', 'stockShortages', 'hasStockShortage', 'updatedAt'];
      return d.keys().hasOnly(requiredKeys.concat(optionalKeys))
          && d.keys().hasAll(requiredKeys)
          // Thông tin khách hàng
          && d.customerName    is string && d.customerName.size()    > 0 && d.customerName.size()    <= 100
          && d.customerPhone   is string && d.customerPhone.size()   > 0 && d.customerPhone.size()   <= 20
          && d.customerAddress is string && d.customerAddress.size() > 0 && d.customerAddress.size() <= 300
          // Phương thức thanh toán chỉ nhận 2 giá trị hợp lệ
          && d.paymentMethod in ['cash', 'transfer']
          // Giỏ hàng hợp lệ
          && validateOrderItems(d.items)
          && d.total is number && d.total >= 0
          && d.status in ['pending', 'shipping', 'unpaid', 'completed']
          && d.source in ['auto', 'website', 'manual']
          && d.timestamp is timestamp
          && d.createdAt is timestamp
          && (!('loyaltyCustomer' in d) || d.loyaltyCustomer is bool)
          && (!('loyaltyPhone' in d) || (d.loyaltyPhone is string && d.loyaltyPhone.size() > 0 && d.loyaltyPhone.size() <= 20))
          && (!('loyaltyOffer' in d) || (d.loyaltyOffer is string && d.loyaltyOffer.size() <= 2000))
          && (!('stockShortages' in d) || validateStockShortages(d.stockShortages))
          && (!('hasStockShortage' in d) || d.hasStockShortage is bool)
          && (!('stockReduced' in d) || d.stockReduced is bool);
    }

    function validateLoyaltyCustomer() {
      let d = request.resource.data;
      let allowed = ['name', 'phone', 'displayPhone', 'passwordHash', 'registeredAt', 'offer', 'updatedAt', 'passwordResetRequired', 'resetRequestedAt'];
      return d.keys().hasOnly(allowed)
          && d.keys().hasAll(['name', 'phone', 'passwordHash', 'registeredAt'])
          && d.name is string && d.name.size() > 0 && d.name.size() <= 100
          && d.phone is string && d.phone.size() > 0 && d.phone.size() <= 20
          && (!('displayPhone' in d) || (d.displayPhone is string && d.displayPhone.size() <= 30))
          && d.passwordHash is string && d.passwordHash.size() > 0
          && d.registeredAt is timestamp
          && (!('offer' in d) || (d.offer is string && d.offer.size() <= 2000))
          && (!('updatedAt' in d) || d.updatedAt is timestamp)
          && (!('passwordResetRequired' in d) || d.passwordResetRequired is bool)
          && (!('resetRequestedAt' in d) || d.resetRequestedAt is timestamp);
    }

    function validateLoyaltyCustomerPasswordReset() {
      let d = request.resource.data;
      let old = resource.data;
      let allowed = ['name', 'phone', 'displayPhone', 'passwordHash', 'registeredAt', 'offer', 'updatedAt', 'passwordResetRequired', 'resetRequestedAt'];
      return request.auth == null
          && old.passwordResetRequired == true
          && d.keys().hasOnly(allowed)
          && d.name == old.name
          && d.phone == old.phone
          && d.registeredAt == old.registeredAt
          && (!('displayPhone' in d) || d.displayPhone == old.displayPhone)
          && (!('offer' in d) || d.offer == old.offer)
          && d.passwordHash is string && d.passwordHash.size() > 0
          && d.passwordResetRequired == false
          && d.updatedAt is timestamp
          && (!('resetRequestedAt' in d) || d.resetRequestedAt == old.resetRequestedAt);
    }

    function validateLoyaltyTemplate() {
      let d = request.resource.data;
      let allowed = ['title', 'content', 'createdAt', 'updatedAt'];
      return d.keys().hasOnly(allowed)
          && d.keys().hasAll(['title', 'content', 'createdAt', 'updatedAt'])
          && d.title is string && d.title.size() > 0 && d.title.size() <= 100
          && d.content is string && d.content.size() > 0 && d.content.size() <= 5000
          && d.createdAt is timestamp
          && d.updatedAt is timestamp;
    }

    function validateContactMessage() {
      let d = request.resource.data;
      return d.keys().hasOnly(['name', 'phone', 'message', 'createdAt', 'status'])
          && d.keys().hasAll(['name', 'phone', 'message', 'createdAt', 'status'])
          && d.name is string && d.name.size() > 0 && d.name.size() <= 100
          && d.phone is string && d.phone.size() > 0 && d.phone.size() <= 20
          && d.message is string && d.message.size() > 0 && d.message.size() <= 2000
          && d.createdAt is timestamp
          && d.status in ['new', 'read'];
    }

    function validateStockMovement() {
      let d = request.resource.data;
      let allowed = ['productId', 'productName', 'type', 'delta', 'previousQuantity', 'newQuantity', 'timestamp', 'location', 'note', 'orderId', 'barcode'];
      return d.keys().hasOnly(allowed)
          && d.keys().hasAll(['productId', 'productName', 'type', 'delta', 'previousQuantity', 'newQuantity', 'timestamp'])
          && d.productId is string && d.productId.size() > 0
          && d.productName is string && d.productName.size() > 0
          && d.type is string && d.type in ['order', 'in', 'out']
          && d.delta is number && d.delta != 0
          && d.previousQuantity is number && d.previousQuantity >= 0
          && d.newQuantity is number && d.newQuantity >= 0
          && d.timestamp is timestamp
          && (!('orderId' in d) || (d.orderId is string && d.orderId.size() > 0))
          && (!('location' in d) || d.location is string)
          && (!('note' in d) || d.note is string)
          && (!('barcode' in d) || d.barcode is string);
    }

    function validateReportBackup() {
      let d = request.resource.data;
      let allowed = ['createdAt', 'totalRevenue', 'totalOrders', 'totalQuantity', 'monthCount'];
      return d.keys().hasOnly(allowed)
          && d.keys().hasAll(['createdAt', 'totalRevenue', 'totalOrders', 'totalQuantity', 'monthCount'])
          && d.createdAt is timestamp
          && d.totalRevenue is number && d.totalRevenue >= 0
          && d.totalOrders is number && d.totalOrders >= 0
          && d.totalQuantity is number && d.totalQuantity >= 0
          && d.monthCount is number && d.monthCount >= 0;
    }

    function validateProductQuantityUpdate() {
      let d = request.resource.data;
      let old = resource.data;
      return d.quantity is number
          && d.quantity >= 0
          && (!('name' in d) || d.name == old.name)
          && (!('price' in d) || d.price == old.price)
          && (!('image' in d) || d.image == old.image)
          && (!('category' in d) || d.category == old.category)
          && (!('barcode' in d) || d.barcode == old.barcode)
          && (!('description' in d) || d.description == old.description)
          && (!('updatedAt' in d) || d.updatedAt is timestamp)
          && (!('location' in d) || d.location is string)
          && (!('note' in d) || d.note is string);
    }

    // ════════════════════════════════════════════════════════
    // RULES
    // ════════════════════════════════════════════════════════

    // Từ chối tất cả các path không được khai báo dưới đây
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── config/{docId} ──────────────────────────────────────
    // GET  /config/settings → index.html đọc ảnh nền + thông tin ngân hàng
    // SET  /config/settings → admin.html lưu cấu hình site
    match /config/{docId} {
      allow get:   if true;
      allow list:  if isAdmin();
      allow create: if isAdmin() && (
                        (docId == 'settings' && validateConfig())
                     || (docId == 'adminOnline' && validateAdminOnline())
                     || (docId == 'reportBackup' && validateReportBackupConfig())
                      );
      allow update: if isAdmin() && (
                        (docId == 'settings' && validateConfig())
                     || (docId == 'adminOnline' && validateAdminOnline())
                     || (docId == 'reportBackup' && validateReportBackupConfig())
                      );
      allow delete: if isAdmin();
    }

    // ─── products/{productId} ────────────────────────────────
    // GET / LIST → index.html & admin.html đọc danh sách sản phẩm
    // CREATE     → admin.html thêm sản phẩm mới
    // DELETE     → admin.html xoá sản phẩm
    // (Không có update từ admin.html nên không mở update cho client)
    match /products/{productId} {
      allow get, list:  if true;
      allow create:     if isAdmin() && validateProduct();
      allow update:     if isAdmin() || (request.auth != null && validateProductQuantityUpdate());
      allow delete:     if isAdmin();
    }

    // ─── stockMovements/{movementId} ───────────────────────────────────────
    match /stockMovements/{movementId} {
      allow get, list: if true;
      allow create:   if request.auth != null && validateStockMovement();
      allow update, delete: if false;
    }

    match /reportBackups/{backupId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && validateReportBackup();
      allow update, delete: if isAdmin();
    }

    match /orderBackups/{backupDocId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ─── orders/{orderId} ────────────────────────────────────
    // CREATE → index.html: bất kỳ khách nào cũng đặt được, phải qua validation
    // READ   → chỉ admin mới xem được đơn hàng (bảo vệ thông tin khách hàng)
    // DELETE → chỉ admin
    // (Không mở update: trạng thái đơn chưa có trong code hiện tại)
    match /orders/{orderId} {
      allow create:        if validateOrder();
      allow get, list,
            delete:        if isAdmin();
      allow update:        if isAdmin() && validateOrder();
    }

    match /loyaltyCustomers/{customerId} {
      allow get:    if true;
      allow list:   if isAdmin();
      allow create: if validateLoyaltyCustomer() && !exists(/databases/$(database)/documents/loyaltyCustomers/$(customerId));
      allow update: if (isAdmin() && validateLoyaltyCustomer()) || validateLoyaltyCustomerPasswordReset();
      allow delete: if isAdmin();
    }

    match /loyaltyTemplates/{templateId} {
      allow get, list: if isAdmin();
      allow create:    if isAdmin() && validateLoyaltyTemplate();
      allow update:    if isAdmin() && validateLoyaltyTemplate();
      allow delete:    if isAdmin();
    }

    // ─── contactMessages/{messageId} ─────────────────────────
    // Khách vãng lai gửi tin nhắn qua form liên hệ trên index.html
    // Admin đọc và cập nhật trạng thái tin nhắn
    match /contactMessages/{messageId} {
      allow create: if validateContactMessage();
      allow get, list, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── restockRequests/{requestId} ─────────────────────────
    match /restockRequests/{requestId} {
      allow create: if validateRestockRequest();
      allow get, list, update, delete: if isAdmin();
    }

    // ─── posts/{postId} ──────────────────────────────────────
    // GET / LIST → mọi người đọc được (hiển thị trên index.html)
    // CREATE / UPDATE / DELETE → chỉ admin
    function validatePost() {
      let d = request.resource.data;
      let allowed = ['title', 'content', 'image', 'tag', 'timestamp'];
      return d.keys().hasOnly(allowed)
          && d.keys().hasAll(['title', 'content', 'timestamp'])
          && d.title   is string && d.title.size()   > 0 && d.title.size()   <= 200
          && d.content is string && d.content.size() > 0 && d.content.size() <= 5000
          && (!('image' in d) || d.image is string)
          && (!('tag'   in d) || d.tag   is string);
    }

    match /posts/{postId} {
      allow get, list:  if true;
      allow create:     if isAdmin() && validatePost();
      allow update:     if isAdmin() && validatePost();
      allow delete:     if isAdmin();
    }

    // ─── chats/{sessionId} ───────────────────────────────────
    // Khách truy cập tạo session và gửi tin nhắn (bằng sessionId lưu localStorage)
    // Admin đọc/trả lời tất cả các cuộc trò chuyện
    match /chats/{sessionId} {
      allow get, create: if true;
      allow list:       if isAdmin();
      allow update:     if true;
      allow delete:     if isAdmin();

      match /messages/{msgId} {
        allow read, create, update: if true;
        allow delete:              if isAdmin();
      }
    }

  }
}
