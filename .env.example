# Example environment variables for local scripts and admin tools
# Copy this file to .env and fill in the real values.

# Path to the Firebase service account JSON file (local only, never commit this file)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Optional: your Firebase project id for local tooling
FIREBASE_PROJECT_ID=

# Optional: add other secrets or environment variables here if you add server-side scripts
# EXAMPLE_SECRET=
