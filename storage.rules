rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── backgrounds/ ──────────────────────────────────────
    // Chỉ admin (đã xác thực) mới upload được ảnh nền
    // Mọi người đều đọc được (public) để hiển thị trên index.html
    match /backgrounds/{filename} {
      allow read:  if true;
      allow write: if request.auth != null
                   // Chỉ chấp nhận file ảnh, tối đa 5 MB
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.size <= 5 * 1024 * 1024;
    }

    // Từ chối tất cả path khác
    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}
